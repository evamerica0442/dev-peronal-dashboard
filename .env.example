# Copy this file to .env and fill in the values.
# See comments in .env for where to get each value.

DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-iam-access-key-id"
AWS_SECRET_ACCESS_KEY="your-iam-secret-access-key"
S3_BUCKET_NAME="dev-hub-tiles"
S3_PUBLIC_URL="https://dev-hub-tiles.s3.us-east-1.amazonaws.com"
